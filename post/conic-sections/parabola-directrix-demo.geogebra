{
  "appName": "classic",
  "height": 460,
  "animation": true,
  "animationObjects": ["P"],
  "view": {
    "xMin": -5,
    "xMax": 5,
    "yMin": -3,
    "yMax": 5
  },
  "commands": [
    "F=(0,1)",
    "d=Line[(-5,-1),(5,-1)]",
    "c=Parabola[F,d]",
    "P=Point[c]",
    "l=PerpendicularLine[P,d]",
    "D=Intersect[l,d]",
    "u=Segment[P,F]",
    "v=Segment[P,D]"
  ]
}
