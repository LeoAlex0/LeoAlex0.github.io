{
  "appName": "classic",
  "height": 460,
  "animation": true,
  "animationObjects": ["P"],
  "view": {
    "xMin": -6,
    "xMax": 6,
    "yMin": -4,
    "yMax": 4
  },
  "commands": [
    "A=(-3,0)",
    "B=(3,0)",
    "c=Ellipse[A,B,4.2]",
    "P=Point[c]",
    "u=Segment[A,P]",
    "v=Segment[P,B]"
  ]
}
